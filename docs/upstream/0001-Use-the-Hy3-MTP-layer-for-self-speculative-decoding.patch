                     layer.mlp.switch_mlp.gate_proj, "all-to-sharded", group=group
diff --git a/tests/test_models.py b/tests/test_models.py
index 8b14e7f..ce1b167 100644
--- a/tests/test_models.py
+++ b/tests/test_models.py
@@ -1827,6 +1827,64 @@ class TestModels(unittest.TestCase):
             model, args.model_type, args.vocab_size, args.num_hidden_layers
         )
 
+    def test_hy_v3_mtp(self):
+        from mlx_lm.models import hy_v3
+
+        args = hy_v3.ModelArgs(
+            model_type="hy_v3",
+            vocab_size=1024,
+            hidden_size=128,
+            intermediate_size=256,
+            num_hidden_layers=4,
+            num_attention_heads=8,
+            num_key_value_heads=2,
+            head_dim=16,
+            num_experts=4,
+            num_experts_per_tok=2,
+            num_shared_experts=1,
+            expert_hidden_dim=128,
+            first_k_dense_replace=1,
+            rms_norm_eps=1e-5,
+            rope_parameters={"rope_theta": 10000.0, "rope_type": "default"},
+            router_scaling_factor=2.0,
+            qk_norm=True,
+            route_norm=True,
+            moe_router_use_sigmoid=True,
+            moe_router_enable_expert_bias=True,
+            num_nextn_predict_layers=1,
+        )
+        model = hy_v3.Model(args)
+        self.assertTrue(hasattr(model, "mtp"))
+
+        # AR path still works and can return hidden states for drafting.
+        inputs = mx.array([[0, 1, 2, 3]])
+        logits, hidden = model(inputs, return_hidden_states=True)
+        self.assertEqual(logits.shape, (1, 4, args.vocab_size))
+        self.assertEqual(hidden.shape, (1, 4, args.hidden_size))
+
+        # The MTP head drafts a next-token distribution from the last hidden
+        # state and the sampled token.
+        draft_logits = model.predict_next_tokens(hidden[:, -1:, :], mx.array([[5]]))
+        self.assertEqual(draft_logits.shape, (1, 1, args.vocab_size))
+
+        # sanitize: MTP weights remap under mtp.* when enabled...
+        weights = {f"model.layers.{args.num_hidden_layers}.enorm.weight": mx.zeros(1)}
+        remapped = model.sanitize(dict(weights))
+        self.assertIn("mtp.enorm.weight", remapped)
+
+        # ...and are dropped under either naming when disabled, so
+        # sidecar-bearing checkpoints still load as AR-only models.
+        from dataclasses import replace
+
+        ar_model = hy_v3.Model(replace(args, num_nextn_predict_layers=0))
+        leftovers = ar_model.sanitize(
+            {
+                "mtp.enorm.weight": mx.zeros(1),
+                f"model.layers.{args.num_hidden_layers}.enorm.weight": mx.zeros(1),
+            }
+        )
+        self.assertEqual(leftovers, {})
+
     def test_hunyuan_v1_dense(self):
         from mlx_lm.models import hunyuan_v1_dense
 

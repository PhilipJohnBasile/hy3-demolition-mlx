diff --git a/mtplx/hy_v3_mtp_patch.py b/mtplx/hy_v3_mtp_patch.py
new file mode 100644
index 0000000..3ed689b
--- /dev/null
+++ b/mtplx/hy_v3_mtp_patch.py
@@ -0,0 +1,67 @@
+"""Hy3 (hy_v3) native MTP support injection.
+
+Unlike families whose MTP layers must be grafted on at load time, the mlx-lm
+hy_v3 model class (MTP revision) already owns its MTP head: with
+``num_nextn_predict_layers > 0`` the checkpoint's mtp.* weights load onto an
+``MTPBlock`` submodule and the model exposes
+``predict_next_tokens(hidden, token_ids, cache)`` plus
+``return_hidden_states=True`` on the trunk forward. Injection here therefore
+reduces to: confirm the config/weights actually carry the head, and expose the
+standard draft-adapter surface the shared speculative sampler consumes.
+
+Draft depth is 1 (Hy3 ships a single NextN layer). The draft layer consumes
+the trunk pre-final-norm hidden state and the just-sampled token's embedding.
+Verification stays in generation.py (exact rejection sampling).
+
+Status: experimental — pending hy_v3 landing in the pinned mlx-lm
+(ml-explore/mlx-lm#1211 + MTP follow-up) and a hardware-measured runtime
+contract.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Any
+
+
+def is_hy_v3_mtp_config(config: dict[str, Any]) -> bool:
+    model_type = str(config.get("model_type", "")).lower()
+    architectures = [str(a) for a in config.get("architectures") or []]
+    if model_type != "hy_v3" and "HyV3ForCausalLM" not in architectures:
+        return False
+    return int(config.get("num_nextn_predict_layers") or 0) > 0
+
+
+def inject_hy_v3_mtp_support(
+    model: Any,
+    path: Path,
+    config: dict[str, Any],
+    contract: Any,
+) -> bool:
+    """Enable Hy3 self-drafting on an already-loaded hy_v3 model.
+
+    Returns True when the model exposes a usable MTP head. Raises if the
+    config promises MTP but the loaded model cannot draft (which points at a
+    checkpoint whose mtp.* weights are missing, e.g. an AR-only export).
+    """
+    if not is_hy_v3_mtp_config(config):
+        return False
+
+    if getattr(model, "num_nextn_predict_layers", 0) <= 0 or not hasattr(model, "mtp"):
+        raise RuntimeError(
+            f"{path}: config declares num_nextn_predict_layers="
+            f"{config.get('num_nextn_predict_layers')} but the loaded model has "
+            "no MTP submodule. The checkpoint is likely an AR-only export "
+            "(model-mtp.safetensors absent) or the installed mlx-lm predates "
+            "hy_v3 MTP support."
+        )
+
+    # The shared sampler drives drafting through these attributes; hy_v3's
+    # native surface already matches, so this is a thin, explicit binding.
+    model.mtplx_mtp_depth = 1
+    model.mtplx_draft_next = model.predict_next_tokens
+    model.mtplx_trunk_wants_hidden = True  # call trunk with return_hidden_states=True
+
+    if contract is not None and hasattr(contract, "note"):
+        contract.note(arch_id="hy-v3-mtp", mtp_depth=1)
+    return True
